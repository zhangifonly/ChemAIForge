// Prisma schema for ChemAIForge
// 文档: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户模型 - 支持学生/教师角色与认证会话
// 注：SQLite 不支持原生 enum，role 以 String 存储，取值约束由应用层 UserRole 保证（STUDENT | TEACHER）
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("STUDENT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 化学实验模型 - 平台核心资源，可交互化学实验
// 注：SQLite 不支持原生 enum，category/difficulty 以 String 存储，
//     取值约束由应用层枚举保证（见 src/server/experiment/types.ts）
// 注：SQLite 不支持 Json 类型，reagents/apparatus/objectives 以 String 存储
//     序列化后的 JSON 数组，读写时由应用层 JSON.parse / JSON.stringify 处理
model Experiment {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  description      String
  category         String // ExperimentCategory: ACID_BASE | ORGANIC | THERMODYNAMICS
  difficulty       String // ExperimentDifficulty: EASY | MEDIUM | HARD
  reagents         String // JSON 字符串：试剂清单 string[]
  apparatus        String // JSON 字符串：仪器清单 string[]
  objectives       String // JSON 字符串：实验目标 string[]
  estimatedMinutes Int
  createdAt        DateTime @default(now())
}

// 健康检查占位模型 - 验证迁移链路是否通畅
model HealthCheck {
  id        String   @id @default(cuid())
  status    String   @default("ok")
  createdAt DateTime @default(now())
}

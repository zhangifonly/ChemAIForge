// Prisma schema for ChemAIForge
// 文档: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户模型 - 支持学生/教师角色与认证会话
// 注：SQLite 不支持原生 enum，role 以 String 存储，取值约束由应用层 UserRole 保证（STUDENT | TEACHER）
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("STUDENT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 健康检查占位模型 - 验证迁移链路是否通畅
model HealthCheck {
  id        String   @id @default(cuid())
  status    String   @default("ok")
  createdAt DateTime @default(now())
}
